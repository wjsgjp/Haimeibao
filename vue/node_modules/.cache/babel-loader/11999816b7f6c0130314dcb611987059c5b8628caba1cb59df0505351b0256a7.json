{"ast":null,"code":"export default {\n  name: 'RiderApply',\n  data() {\n    return {\n      params: {\n        name: '',\n        sex: '',\n        college: '',\n        status: ''\n      },\n      tableData: [],\n      imageDialogVisible: false,\n      images: {\n        studentCard: '',\n        healthCard: ''\n      }\n    };\n  },\n  created() {\n    this.load();\n  },\n  methods: {\n    load() {\n      // 构建查询参数，只包含有值的字段\n      const queryParams = {};\n      if (this.params.name) queryParams.name = this.params.name;\n      if (this.params.sex) queryParams.sex = this.params.sex;\n      if (this.params.status) queryParams.status = this.params.status;\n      this.$request.get('/riderApply/listWithoutImages', {\n        params: queryParams // 添加查询参数\n      }).then(res => {\n        if (res.code === '200') {\n          this.tableData = res.data;\n          console.log('获取到的骑手申请列表：', this.tableData);\n        }\n      });\n    },\n    reset() {\n      this.params = {\n        name: '',\n        sex: '',\n        college: '',\n        status: ''\n      };\n      this.load();\n    },\n    viewImages(row) {\n      this.$request.get(`/riderApply/getImages/${row.id}`).then(res => {\n        if (res.code === '200') {\n          this.images = res.data;\n          console.log('获取到的证件图片：', this.images);\n          this.imageDialogVisible = true;\n        }\n      });\n    },\n    handleAudit(row, status) {\n      // 将中文状态转换为API所需的英文状态\n      const apiStatus = status === '通过' ? 'pass' : 'reject';\n      this.$confirm(`确认${status}该申请吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        console.log('准备审核的申请：', row);\n        console.log('审核状态：', apiStatus);\n\n        // 修改为PUT请求，使用路径参数\n        this.$request.put(`/riderApply/audit/${row.id}/${apiStatus}`).then(res => {\n          if (res.code === '200') {\n            this.$message.success('操作成功');\n            this.load(); // 重新加载列表\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    }\n  }\n};","map":{"version":3,"names":["name","data","params","sex","college","status","tableData","imageDialogVisible","images","studentCard","healthCard","created","load","methods","queryParams","$request","get","then","res","code","console","log","reset","viewImages","row","id","handleAudit","apiStatus","$confirm","confirmButtonText","cancelButtonText","type","put","$message","success","error","msg","catch"],"sources":["src/views/manager/RiderApply.vue"],"sourcesContent":["<template>\n  <div>\n    <div class=\"search\">\n      <el-input placeholder=\"请输入姓名\" style=\"width: 200px\" v-model=\"params.name\" ></el-input>\n      <el-select v-model=\"params.sex\" placeholder=\"性别\" style=\"width: 120px; margin-left: 10px\" >\n        <el-option label=\"男\" value=\"男\"></el-option>\n        <el-option label=\"女\" value=\"女\"></el-option>\n      </el-select>\n      <el-select v-model=\"params.status\" placeholder=\"状态\" style=\"width: 120px; margin-left: 10px\" >\n        <el-option label=\"审核中\" value=\"审核中\"></el-option>\n        <el-option label=\"通过\" value=\"通过\"></el-option>\n        <el-option label=\"拒绝\" value=\"拒绝\"></el-option>\n      </el-select>\n      <el-button type=\"primary\" style=\"margin-left: 10px\" @click=\"load\" >查询</el-button>\n      <el-button type=\"warning\" style=\"margin-left: 10px\" @click=\"reset\" >重置</el-button>\n    </div>\n\n    <el-table :data=\"tableData\" stripe>\n      <el-table-column prop=\"id\" label=\"ID\" width=\"80\" align=\"center\"></el-table-column>\n      <el-table-column prop=\"name\" label=\"姓名\" align=\"center\"></el-table-column>\n      <el-table-column prop=\"sex\" label=\"性别\" width=\"80\" align=\"center\"></el-table-column>\n      <el-table-column prop=\"college\" label=\"学院\" align=\"center\"></el-table-column>\n      <el-table-column prop=\"majorClass\" label=\"班级\" align=\"center\"></el-table-column>\n      <el-table-column prop=\"status\" label=\"状态\" align=\"center\">\n        <template v-slot=\"scope\">\n          <el-tag type=\"warning\" v-if=\"scope.row.status === '审核中'\">审核中</el-tag>\n          <el-tag type=\"success\" v-if=\"scope.row.status === '通过'\">通过</el-tag>\n          <el-tag type=\"danger\" v-if=\"scope.row.status === '拒绝'\">拒绝</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"createTime\" label=\"申请时间\" align=\"center\"></el-table-column>\n      <el-table-column label=\"操作\" width=\"280\" align=\"center\">\n        <template v-slot=\"scope\">\n          <el-button type=\"primary\" size=\"mini\" @click=\"viewImages(scope.row)\">查看证件</el-button>\n          <el-button type=\"success\" size=\"mini\" @click=\"handleAudit(scope.row, '通过')\" \n                     v-if=\"scope.row.status === '审核中'\">通过</el-button>\n          <el-button type=\"danger\" size=\"mini\" @click=\"handleAudit(scope.row, '拒绝')\" \n                     v-if=\"scope.row.status === '审核中'\">拒绝</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <!-- 图片查看对话框 -->\n    <el-dialog title=\"证件图片\" :visible.sync=\"imageDialogVisible\" width=\"60%\">\n      <div style=\"text-align: center\">\n        <div class=\"image-container\">\n          <h3>学生证</h3>\n          <el-image \n            style=\"width: 400px\" \n            :src=\"images.studentCard\" \n            :preview-src-list=\"[images.studentCard]\">\n          </el-image>\n        </div>\n        <div class=\"image-container\">\n          <h3>健康证</h3>\n          <el-image \n            style=\"width: 400px\" \n            :src=\"images.healthCard\" \n            :preview-src-list=\"[images.healthCard]\">\n          </el-image>\n        </div>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'RiderApply',\n  data() {\n    return {\n      params: {\n        name: '',\n        sex: '',\n        college: '',\n        status: ''\n      },\n      tableData: [],\n      imageDialogVisible: false,\n      images: {\n        studentCard: '',\n        healthCard: ''\n      }\n    }\n  },\n  created() {\n    this.load()\n  },\n  methods: {\n    load() {\n      // 构建查询参数，只包含有值的字段\n      const queryParams = {}\n      if (this.params.name) queryParams.name = this.params.name\n      if (this.params.sex) queryParams.sex = this.params.sex\n      if (this.params.status) queryParams.status = this.params.status\n\n      this.$request.get('/riderApply/listWithoutImages', {\n        params: queryParams  // 添加查询参数\n      }).then(res => {\n        if (res.code === '200') {\n          this.tableData = res.data\n          console.log('获取到的骑手申请列表：', this.tableData)\n        }\n      })\n    },\n    reset() {\n      this.params = {\n        name: '',\n        sex: '',\n        college: '',\n        status: ''\n      }\n      this.load()\n    },\n    viewImages(row) {\n      this.$request.get(`/riderApply/getImages/${row.id}`).then(res => {\n        if (res.code === '200') {\n          this.images = res.data\n          console.log('获取到的证件图片：', this.images)\n          this.imageDialogVisible = true\n        }\n      })\n    },\n    handleAudit(row, status) {\n      // 将中文状态转换为API所需的英文状态\n      const apiStatus = status === '通过' ? 'pass' : 'reject'\n      \n      this.$confirm(`确认${status}该申请吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        console.log('准备审核的申请：', row)\n        console.log('审核状态：', apiStatus)\n        \n        // 修改为PUT请求，使用路径参数\n        this.$request.put(`/riderApply/audit/${row.id}/${apiStatus}`).then(res => {\n          if (res.code === '200') {\n            this.$message.success('操作成功')\n            this.load()  // 重新加载列表\n          } else {\n            this.$message.error(res.msg)\n          }\n        })\n      }).catch(() => {})\n    }\n  }\n}\n</script>\n\n<style scoped>\n.search {\n  margin-bottom: 20px;\n}\n.image-container {\n  margin: 20px 0;\n}\n</style> "],"mappings":"AAmEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,MAAA;QACAF,IAAA;QACAG,GAAA;QACAC,OAAA;QACAC,MAAA;MACA;MACAC,SAAA;MACAC,kBAAA;MACAC,MAAA;QACAC,WAAA;QACAC,UAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAD,KAAA;MACA;MACA,MAAAE,WAAA;MACA,SAAAZ,MAAA,CAAAF,IAAA,EAAAc,WAAA,CAAAd,IAAA,QAAAE,MAAA,CAAAF,IAAA;MACA,SAAAE,MAAA,CAAAC,GAAA,EAAAW,WAAA,CAAAX,GAAA,QAAAD,MAAA,CAAAC,GAAA;MACA,SAAAD,MAAA,CAAAG,MAAA,EAAAS,WAAA,CAAAT,MAAA,QAAAH,MAAA,CAAAG,MAAA;MAEA,KAAAU,QAAA,CAAAC,GAAA;QACAd,MAAA,EAAAY,WAAA;MACA,GAAAG,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA;UACA,KAAAb,SAAA,GAAAY,GAAA,CAAAjB,IAAA;UACAmB,OAAA,CAAAC,GAAA,qBAAAf,SAAA;QACA;MACA;IACA;IACAgB,MAAA;MACA,KAAApB,MAAA;QACAF,IAAA;QACAG,GAAA;QACAC,OAAA;QACAC,MAAA;MACA;MACA,KAAAO,IAAA;IACA;IACAW,WAAAC,GAAA;MACA,KAAAT,QAAA,CAAAC,GAAA,0BAAAQ,GAAA,CAAAC,EAAA,IAAAR,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA;UACA,KAAAX,MAAA,GAAAU,GAAA,CAAAjB,IAAA;UACAmB,OAAA,CAAAC,GAAA,mBAAAb,MAAA;UACA,KAAAD,kBAAA;QACA;MACA;IACA;IACAmB,YAAAF,GAAA,EAAAnB,MAAA;MACA;MACA,MAAAsB,SAAA,GAAAtB,MAAA;MAEA,KAAAuB,QAAA,MAAAvB,MAAA;QACAwB,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAd,IAAA;QACAG,OAAA,CAAAC,GAAA,aAAAG,GAAA;QACAJ,OAAA,CAAAC,GAAA,UAAAM,SAAA;;QAEA;QACA,KAAAZ,QAAA,CAAAiB,GAAA,sBAAAR,GAAA,CAAAC,EAAA,IAAAE,SAAA,IAAAV,IAAA,CAAAC,GAAA;UACA,IAAAA,GAAA,CAAAC,IAAA;YACA,KAAAc,QAAA,CAAAC,OAAA;YACA,KAAAtB,IAAA;UACA;YACA,KAAAqB,QAAA,CAAAE,KAAA,CAAAjB,GAAA,CAAAkB,GAAA;UACA;QACA;MACA,GAAAC,KAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}