{"ast":null,"code":"export default {\n  name: 'RiderApply',\n  data() {\n    return {\n      params: {\n        name: '',\n        sex: '',\n        college: '',\n        status: ''\n      },\n      tableData: [],\n      imageDialogVisible: false,\n      images: {\n        studentCard: '',\n        healthCard: ''\n      }\n    };\n  },\n  created() {\n    this.load();\n  },\n  methods: {\n    load() {\n      this.$request.get('/riderApply/listWithoutImages', {\n        params: this.params\n      }).then(res => {\n        if (res.code === '200') {\n          this.tableData = res.data;\n        }\n      });\n    },\n    reset() {\n      this.params = {\n        name: '',\n        sex: '',\n        college: '',\n        status: ''\n      };\n      this.load();\n    },\n    viewImages(row) {\n      this.$request.get(`/riderApply/getImages/${row.id}`).then(res => {\n        if (res.code === '200') {\n          this.images = res.data;\n          this.imageDialogVisible = true;\n        }\n      });\n    },\n    handleAudit(row, status) {\n      this.$confirm(`确认${status}该申请吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        // 这里需要后端提供审核的API\n        this.$request.post('/riderApply/audit', {\n          id: row.id,\n          status: status\n        }).then(res => {\n          if (res.code === '200') {\n            this.$message.success('操作成功');\n            this.load();\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    }\n  }\n};","map":{"version":3,"names":["name","data","params","sex","college","status","tableData","imageDialogVisible","images","studentCard","healthCard","created","load","methods","$request","get","then","res","code","reset","viewImages","row","id","handleAudit","$confirm","confirmButtonText","cancelButtonText","type","post","$message","success","error","msg","catch"],"sources":["src/views/manager/RiderApply.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"search\">\r\n      <el-input placeholder=\"请输入姓名\" style=\"width: 200px\" v-model=\"params.name\"></el-input>\r\n      <el-select v-model=\"params.sex\" placeholder=\"性别\" style=\"width: 120px; margin-left: 10px\">\r\n        <el-option label=\"男\" value=\"男\"></el-option>\r\n        <el-option label=\"女\" value=\"女\"></el-option>\r\n      </el-select>\r\n      <el-input placeholder=\"请输入学院\" style=\"width: 200px; margin-left: 10px\" v-model=\"params.college\"></el-input>\r\n      <el-select v-model=\"params.status\" placeholder=\"状态\" style=\"width: 120px; margin-left: 10px\">\r\n        <el-option label=\"审核中\" value=\"审核中\"></el-option>\r\n        <el-option label=\"通过\" value=\"通过\"></el-option>\r\n        <el-option label=\"拒绝\" value=\"拒绝\"></el-option>\r\n      </el-select>\r\n      <el-button type=\"primary\" style=\"margin-left: 10px\" @click=\"load\">查询</el-button>\r\n      <el-button type=\"warning\" style=\"margin-left: 10px\" @click=\"reset\">重置</el-button>\r\n    </div>\r\n\r\n    <el-table :data=\"tableData\" stripe>\r\n      <el-table-column prop=\"id\" label=\"ID\" width=\"80\" align=\"center\"></el-table-column>\r\n      <el-table-column prop=\"name\" label=\"姓名\" align=\"center\"></el-table-column>\r\n      <el-table-column prop=\"sex\" label=\"性别\" width=\"80\" align=\"center\"></el-table-column>\r\n      <el-table-column prop=\"college\" label=\"学院\" align=\"center\"></el-table-column>\r\n      <el-table-column prop=\"majorClass\" label=\"班级\" align=\"center\"></el-table-column>\r\n      <el-table-column prop=\"status\" label=\"状态\" align=\"center\">\r\n        <template v-slot=\"scope\">\r\n          <el-tag type=\"warning\" v-if=\"scope.row.status === '审核中'\">审核中</el-tag>\r\n          <el-tag type=\"success\" v-if=\"scope.row.status === '通过'\">通过</el-tag>\r\n          <el-tag type=\"danger\" v-if=\"scope.row.status === '拒绝'\">拒绝</el-tag>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"createTime\" label=\"申请时间\" align=\"center\"></el-table-column>\r\n      <el-table-column label=\"操作\" width=\"280\" align=\"center\">\r\n        <template v-slot=\"scope\">\r\n          <el-button type=\"primary\" size=\"mini\" @click=\"viewImages(scope.row)\">查看证件</el-button>\r\n          <el-button type=\"success\" size=\"mini\" @click=\"handleAudit(scope.row, '通过')\" \r\n                     v-if=\"scope.row.status === '审核中'\">通过</el-button>\r\n          <el-button type=\"danger\" size=\"mini\" @click=\"handleAudit(scope.row, '拒绝')\" \r\n                     v-if=\"scope.row.status === '审核中'\">拒绝</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n\r\n    <!-- 图片查看对话框 -->\r\n    <el-dialog title=\"证件图片\" :visible.sync=\"imageDialogVisible\" width=\"60%\">\r\n      <div style=\"text-align: center\">\r\n        <div class=\"image-container\">\r\n          <h3>学生证</h3>\r\n          <el-image \r\n            style=\"width: 400px\" \r\n            :src=\"images.studentCard\" \r\n            :preview-src-list=\"[images.studentCard]\">\r\n          </el-image>\r\n        </div>\r\n        <div class=\"image-container\">\r\n          <h3>健康证</h3>\r\n          <el-image \r\n            style=\"width: 400px\" \r\n            :src=\"images.healthCard\" \r\n            :preview-src-list=\"[images.healthCard]\">\r\n          </el-image>\r\n        </div>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'RiderApply',\r\n  data() {\r\n    return {\r\n      params: {\r\n        name: '',\r\n        sex: '',\r\n        college: '',\r\n        status: ''\r\n      },\r\n      tableData: [],\r\n      imageDialogVisible: false,\r\n      images: {\r\n        studentCard: '',\r\n        healthCard: ''\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.load()\r\n  },\r\n  methods: {\r\n    load() {\r\n      this.$request.get('/riderApply/listWithoutImages', {\r\n        params: this.params\r\n      }).then(res => {\r\n        if (res.code === '200') {\r\n          this.tableData = res.data\r\n        }\r\n      })\r\n    },\r\n    reset() {\r\n      this.params = {\r\n        name: '',\r\n        sex: '',\r\n        college: '',\r\n        status: ''\r\n      }\r\n      this.load()\r\n    },\r\n    viewImages(row) {\r\n      this.$request.get(`/riderApply/getImages/${row.id}`).then(res => {\r\n        if (res.code === '200') {\r\n          this.images = res.data\r\n          this.imageDialogVisible = true\r\n        }\r\n      })\r\n    },\r\n    handleAudit(row, status) {\r\n      this.$confirm(`确认${status}该申请吗？`, '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(() => {\r\n        // 这里需要后端提供审核的API\r\n        this.$request.post('/riderApply/audit', {\r\n          id: row.id,\r\n          status: status\r\n        }).then(res => {\r\n          if (res.code === '200') {\r\n            this.$message.success('操作成功')\r\n            this.load()\r\n          } else {\r\n            this.$message.error(res.msg)\r\n          }\r\n        })\r\n      }).catch(() => {})\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.search {\r\n  margin-bottom: 20px;\r\n}\r\n.image-container {\r\n  margin: 20px 0;\r\n}\r\n</style> "],"mappings":"AAoEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,MAAA;QACAF,IAAA;QACAG,GAAA;QACAC,OAAA;QACAC,MAAA;MACA;MACAC,SAAA;MACAC,kBAAA;MACAC,MAAA;QACAC,WAAA;QACAC,UAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAD,KAAA;MACA,KAAAE,QAAA,CAAAC,GAAA;QACAb,MAAA,OAAAA;MACA,GAAAc,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA;UACA,KAAAZ,SAAA,GAAAW,GAAA,CAAAhB,IAAA;QACA;MACA;IACA;IACAkB,MAAA;MACA,KAAAjB,MAAA;QACAF,IAAA;QACAG,GAAA;QACAC,OAAA;QACAC,MAAA;MACA;MACA,KAAAO,IAAA;IACA;IACAQ,WAAAC,GAAA;MACA,KAAAP,QAAA,CAAAC,GAAA,0BAAAM,GAAA,CAAAC,EAAA,IAAAN,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA;UACA,KAAAV,MAAA,GA